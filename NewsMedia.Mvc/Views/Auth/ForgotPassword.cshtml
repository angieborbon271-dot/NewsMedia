@{
    ViewData["Title"] = "Recuperar contraseña";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .auth-wrap {
        display: flex;
        min-height: 60vh;
        align-items: center;
        justify-content: center;
        padding: 2rem 0;
    }

    .auth-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 30px rgba(0,0,0,.1);
        overflow: hidden;
        width: 100%;
        max-width: 900px;
        display: flex;
    }

    .auth-side {
        background: linear-gradient(160deg,#1a1a2e 0%,#2c3e50 100%);
        color: #fff;
        padding: 3rem 2.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        width: 340px;
        min-width: 340px;
    }

        .auth-side .brand {
            font-family: 'Playfair Display',serif;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 1rem;
        }

            .auth-side .brand span {
                color: #c0392b;
            }

        .auth-side .tagline {
            font-size: .65rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,.4);
            margin-bottom: 1.2rem;
        }

        .auth-side p {
            color: rgba(255,255,255,.6);
            font-size: .88rem;
            line-height: 1.7;
            margin: 0;
        }

    .auth-form {
        padding: 3rem 3rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .auth-form h4 {
            font-family: 'Playfair Display',serif;
            font-size: 1.6rem;
            color: #1a1a2e;
            margin-bottom: .4rem;
        }

        .auth-form .sub {
            color: #888;
            font-size: .85rem;
            margin-bottom: 2rem;
        }

    .form-label {
        font-size: .85rem;
        font-weight: 600;
        color: #333;
    }

    .form-control {
        border-radius: 8px;
        border: 1.5px solid #e5e5e5;
        padding: .65rem .9rem;
        font-size: .9rem;
        transition: all .2s;
    }

        .form-control:focus {
            border-color: #1a1a2e;
            box-shadow: 0 0 0 3px rgba(26,26,46,.08);
        }

    .btn-submit {
        background: #c0392b;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .75rem;
        font-weight: 700;
        font-size: .95rem;
        width: 100%;
        transition: all .2s;
        cursor: pointer;
    }

        .btn-submit:hover {
            background: #a93226;
            transform: translateY(-1px);
        }

    .temp-pass-box {
        background: #f0faf5;
        border: 1.5px solid #27ae60;
        border-radius: 10px;
        padding: 1.2rem 1.5rem;
        margin-bottom: 1.5rem;
    }

    .temp-pass-val {
        font-family: monospace;
        font-size: 1.5rem;
        font-weight: 700;
        color: #1a1a2e;
        letter-spacing: 3px;
        background: #fff;
        border: 1px dashed #27ae60;
        border-radius: 6px;
        padding: 8px 16px;
        display: block;
        text-align: center;
        margin-top: .5rem;
    }

    @@media(max-width:640px) {
        .auth-side {
            display: none;
        }

        .auth-form {
            padding: 2rem;
        }
    }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-side">
            <div class="brand">News<span>Media</span></div>
            <div class="tagline">Tu portal de noticias</div>
            <p>
                Ingresa tu correo registrado y te generaremos una contraseña temporal para que puedas acceder.
                Luego podrás cambiarla desde tu perfil en "Cambiar contraseña".
            </p>
        </div>
        <div class="auth-form">
            <h4>Recuperar contraseña</h4>
            <p class="sub">Te generaremos una contraseña temporal al instante</p>

            @if (ViewBag.Success == true)
            {
                <div class="temp-pass-box">
                    <div style="font-size:.88rem;font-weight:600;color:#1a6b3a;">✅ Contraseña restablecida exitosamente</div>
                    <div style="font-size:.82rem;color:#555;margin-top:.3rem;">Tu nueva contraseña temporal es:</div>
                    <span class="temp-pass-val">@ViewBag.TempPassword</span>
                    <div style="font-size:.75rem;color:#888;margin-top:.6rem;">⚠️ Inicia sesión y cámbiala desde tu perfil.</div>
                </div>
                <a href="/Auth/Login" class="btn-submit d-block text-center text-decoration-none" style="line-height:2.8;">
                    Ir a iniciar sesión
                </a>
            }
            else
            {
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 mb-3" style="border-radius:8px;font-size:.88rem;">
                        ⚠️ @ViewBag.Error
                    </div>
                }
                <form method="post" action="/Auth/ForgotPassword">
                    <div class="mb-4">
                        <label class="form-label">Correo electrónico de tu cuenta</label>
                        <input type="email" name="email" class="form-control" placeholder="tu@correo.com" required />
                    </div>
                    <button type="submit" class="btn-submit">Generar contraseña temporal</button>
                </form>
                <hr style="margin:1.8rem 0;border-color:#f0f0f0;" />
                <p class="text-center mb-0" style="font-size:.88rem;color:#888;">
                    ¿Recordaste tu contraseña?
                    <a href="/Auth/Login" style="color:#c0392b;font-weight:600;text-decoration:none;">Inicia sesión</a>
                </p>
            }
        </div>
    </div>
</div>