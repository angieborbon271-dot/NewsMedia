@model List<NewsMedia.Models.Setting>
@{
    ViewData["Title"] = "Configuración";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var users = ViewBag.Users as List<System.Text.Json.JsonElement> ?? new();
    var currentUserId = Context.Session.GetString("UserId") ?? "";
}
<style>
    .admin-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
        overflow: hidden;
        height: 100%;
    }

    .admin-card-header {
        background: #1a1a2e;
        color: #fff;
        padding: 14px 20px;
        font-weight: 700;
        font-size: .88rem;
        letter-spacing: .3px;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .admin-card-body {
        padding: 1.5rem;
    }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1.5px solid #e5e5e5;
        font-size: .85rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: #1a1a2e;
            box-shadow: 0 0 0 3px rgba(26,26,46,.08);
        }

    .setting-row {
        display: flex;
        align-items: center;
        padding: 9px 0;
        border-bottom: 1px solid #f5f5f5;
        gap: .5rem;
    }

        .setting-row:last-child {
            border-bottom: none;
        }

    .setting-key {
        font-weight: 700;
        font-size: .82rem;
        color: #1a1a2e;
        flex: 1;
    }

    .setting-val {
        font-family: monospace;
        font-size: .78rem;
        color: #555;
        background: #f7f7f9;
        padding: 3px 8px;
        border-radius: 5px;
    }

    .user-row {
        display: flex;
        align-items: center;
        padding: 9px 0;
        border-bottom: 1px solid #f5f5f5;
        gap: .8rem;
    }

        .user-row:last-child {
            border-bottom: none;
        }

    .user-email {
        flex: 1;
        font-size: .85rem;
        color: #333;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .role-pill {
        border-radius: 20px;
        padding: 3px 10px;
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .role-admin {
        background: #fee2e2;
        color: #c0392b;
    }

    .role-user {
        background: #e0f0ff;
        color: #1a5fa8;
    }

    .role-viewer {
        background: #f0f0f0;
        color: #555;
    }

    .btn-save-role {
        background: #1a1a2e;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 4px 10px;
        font-size: .78rem;
        font-weight: 600;
        transition: all .2s;
    }

        .btn-save-role:hover {
            background: #c0392b;
        }

    .empty-msg {
        text-align: center;
        color: #bbb;
        padding: 2rem;
        font-size: .85rem;
    }
</style>

<h2 class="fw-bold mb-4" style="font-family:'Playfair Display',serif;color:#1a1a2e;">⚙️ Configuración del Sistema</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius:10px;">
        ✅ @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- SECRETS -->
    <div class="col-md-5">
        <div class="admin-card">
            <div class="admin-card-header">🔑 Secrets y Configuración</div>
            <div class="admin-card-body">
                <form method="post" action="/Admin/CreateSetting" class="d-flex gap-2 mb-3">
                    <input name="key" placeholder="Clave (ej: NEWS_API_KEY)" class="form-control" required />
                    <input name="value" placeholder="Valor" class="form-control" required />
                    <button type="submit" class="btn btn-sm text-white fw-bold"
                            style="background:#c0392b;border-radius:8px;padding:0 14px;white-space:nowrap;">
                        +
                    </button>
                </form>

                @if (!Model.Any())
                {
                    <div class="empty-msg">No hay secrets configurados</div>
                }
                else
                {
                    @foreach (var s in Model)
                    {
                        <div class="setting-row">
                            <span class="setting-key">@s.Key</span>
                            <span class="setting-val">@(s.Value?.Length > 18 ? s.Value[..18] + "…" : s.Value)</span>
                            <form method="post" action="/Admin/DeleteSetting" class="d-inline ms-1">
                                <input type="hidden" name="id" value="@s.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        style="border-radius:6px;padding:2px 8px;font-size:.78rem;"
                                        onclick="return confirm('¿Eliminar «@s.Key»?')">
                                    🗑️
                                </button>
                            </form>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- ROLES -->
    <div class="col-md-7">
        <div class="admin-card">
            <div class="admin-card-header">👥 Gestión de Roles — @users.Count usuario@(users.Count != 1 ? "s" : "")</div>
            <div class="admin-card-body">
                @if (!users.Any())
                {
                    <div class="empty-msg">No hay usuarios registrados</div>
                }
                else
                {
                    <div style="font-size:.72rem;color:#aaa;text-transform:uppercase;letter-spacing:1px;margin-bottom:.8rem;display:grid;grid-template-columns:1fr 80px 130px 36px 36px;gap:.5rem;">
                        <span>Email</span><span>Rol actual</span><span>Cambiar a</span><span></span><span></span>
                    </div>
                    @foreach (var u in users)
                    {
                        var uid = u.TryGetProperty("id", out var i) ? i.GetString() : "";
                        var email = u.TryGetProperty("email", out var e) ? e.GetString() : "";
                        var role = u.TryGetProperty("role", out var r) ? r.GetString() : "user";
                        var isSelf = uid == currentUserId;
                        <div class="user-row">
                            <span class="user-email" title="@email">@email</span>
                            <span class="role-pill role-@role">@role</span>
                            <form method="post" action="/Admin/UpdateRole" class="d-flex gap-1 align-items-center">
                                <input type="hidden" name="id" value="@uid" />
                                <select name="role" class="form-select form-select-sm" style="font-size:.8rem;border-radius:6px;">
                                    <option value="admin" selected="@(role == "admin")">admin</option>
                                    <option value="user" selected="@(role == "user")">user</option>
                                    <option value="viewer" selected="@(role == "viewer")">viewer</option>
                                </select>
                                <button type="submit" class="btn-save-role">✓</button>
                            </form>
                            <form method="post" action="/Admin/DeleteUser" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar a @email? Esta acción no se puede deshacer.')">
                                <input type="hidden" name="id" value="@uid" />
                                <button type="submit"
                                        class="btn btn-sm btn-outline-danger"
                                        style="border-radius:6px;padding:3px 8px;font-size:.78rem;"
                                    @(isSelf ? "disabled title=\"No puedes eliminarte a ti mismo\"" : "")>
                                    🗑️
                                </button>
                            </form>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>